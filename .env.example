# ---------------------------------------------------------------------------
# Personal Agent — environment variables
# Copy to .env.local for local dev; set the same keys in Vercel for production.
# Never commit real secrets. Generate random hex with: openssl rand -hex 32
# ---------------------------------------------------------------------------

# --- Supabase (Postgres + pgvector) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # server only — bypasses RLS

# --- Anthropic (reasoning, drafting) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6     # model used by the agent core

# --- OpenAI (Whisper transcription + embeddings) ---
# Optional/swappable. Without it, voice + ambient-memory retrieval degrade gracefully.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small   # 1536 dims — matches the schema
OPENAI_TRANSCRIBE_MODEL=whisper-1

# --- Dashboard auth (single user) ---
AUTH_SECRET=                          # openssl rand -hex 32
DASHBOARD_PASSWORD=                   # your choice
API_SECRET=                           # random hex — x-api-secret header for programmatic calls
CRON_SECRET=                          # random hex — Authorization: Bearer for /api/agent/tick

# --- Telegram (the agent's channel) ---
TELEGRAM_BOT_TOKEN=                   # from @BotFather
TELEGRAM_WEBHOOK_SECRET=              # random hex — verifies inbound webhooks
TELEGRAM_USER_ID=                     # your numeric id from @userinfobot (bot ignores everyone else)

# --- Google APIs (Gmail + Calendar) — added in Part 2 / Part 4 ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=           # stored after consent (encrypt at rest)

# --- Single-user identity / locale ---
USER_ID=primary                       # static string for the single user
USER_TIMEZONE=Asia/Baghdad            # IANA tz — "today"/check-ins/reviews computed here
